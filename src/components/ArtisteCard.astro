---
// Composant carte d'artiste - Design fidele au site original
const { artiste } = Astro.props;

// URL de l'image PocketBase
const imageUrl = artiste.photo 
  ? `http://127.0.0.1:8090/api/files/artistes/${artiste.id}/${artiste.photo}`
  : '/placeholder.jpg';

// Formater la date simplement
function formatDate(dateString) {
  if (!dateString) return '';
  const date = new Date(dateString);
  return `${date.getDate()} Decembre`;
}
---

<a href={`/artistes/${artiste.id}`} class="group block">
  <article class="relative bg-[#2A2A3E] rounded-xl overflow-hidden border border-white/10 hover:border-[#FDC700]/50 transition-all hover:scale-[1.02]">
    
    <!-- Image -->
    <div class="aspect-square overflow-hidden">
      <img 
        src={imageUrl} 
        alt={artiste.nom} 
        class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
      />
      <!-- Overlay gradient -->
      <div class="absolute inset-0 bg-gradient-to-t from-[#1A1A2E] via-transparent to-transparent"></div>
    </div>

    <!-- Contenu -->
    <div class="absolute bottom-0 left-0 right-0 p-4">
      <h3 class="text-white font-bold text-lg group-hover:text-[#FDC700] transition-colors mb-1">
        {artiste.nom}
      </h3>
      
      <div class="flex items-center gap-2 text-sm">
        {artiste.date_representation && (
          <span class="text-[#FDC700]">{formatDate(artiste.date_representation)}</span>
        )}
        {artiste.genre && (
          <>
            <span class="text-white/30">-</span>
            <span class="text-white/60">{artiste.genre}</span>
          </>
        )}
      </div>
    </div>

  </article>
</a>
