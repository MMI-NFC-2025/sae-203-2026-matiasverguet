---
import logo from '../assets/icons/logo.svg';
---

<header style="background: red; color: white; padding: 1rem 0; position:relative;">
	<div style="max-width: 1100px; margin: 0 auto; padding: 0 1rem; display:flex; align-items:center; justify-content:space-between;">
		<a href="/" style="display:inline-block;">
			<img src={logo.src} alt="Le Festival" style="height:40px; display:block;" />
		</a>
		<div class="nav-container" style="position:relative;">
			<button id="burger-btn" aria-label="Menu" aria-expanded="false" style="background:none;border:none;padding:0;margin:0;cursor:pointer;display:flex;align-items:center;">
				<span class="burger" style="display:flex;flex-direction:column;justify-content:center;align-items:center;padding:6px;">
					<span style="display:block;width:26px;height:3px;background:white;margin:4px 0;border-radius:2px;"></span>
					<span style="display:block;width:26px;height:3px;background:white;margin:4px 0;border-radius:2px;"></span>
					<span style="display:block;width:26px;height:3px;background:white;margin:4px 0;border-radius:2px;"></span>
				</span>
				<span class="close" style="display:none;padding:6px;color:white;font-size:28px;line-height:1;">×</span>
			</button>

			<div id="burger-menu" style="display:none; position:fixed; left:0; right:0; top:0; background:red; color:white; padding:0; border-radius:0; z-index:40; justify-content:center; align-items:center;">
				<nav style="width:100%;">
					<div style="max-width:1100px;margin:0 auto;padding:2rem 1rem;display:flex;flex-direction:column;align-items:center;">
						<a href="/festival" style="display:block;padding:1.25rem 0;color:inherit;text-decoration:none;font-size:2rem;text-align:center;">Le festival</a>
						<a href="/[Idprogramme]" style="display:block;padding:1.25rem 0;color:inherit;text-decoration:none;font-size:2rem;text-align:center;">Programme</a>
						<a href="/artistes" style="display:block;padding:1.25rem 0;color:inherit;text-decoration:none;font-size:2rem;text-align:center;">Artistes</a>
						<a href="/[IdScene]" style="display:block;padding:1.25rem 0;color:inherit;text-decoration:none;font-size:2rem;text-align:center;">Scènes</a>
						<a href="/infos" style="display:block;padding:1.25rem 0;color:inherit;text-decoration:none;font-size:2rem;text-align:center;">Info pratique</a>
						<a href="/contact" style="display:block;padding:1.25rem 0;color:inherit;text-decoration:none;font-size:2rem;text-align:center;">Contact</a>
					</div>
				</nav>
			</div>
		</div>
	</div>
</header>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const btn = document.getElementById('burger-btn');
		const menu = document.getElementById('burger-menu');
		const headerEl = document.querySelector('header');
		if (!btn || !menu || !headerEl) return;

		// find burger/close elements
		const burgerEl = btn.querySelector('.burger');
		const closeEl = btn.querySelector('.close');

		function openMenu() {
			const rect = headerEl.getBoundingClientRect();
			const top = rect.bottom;
			menu.style.display = 'flex';
			menu.style.top = top + 'px';
			menu.style.height = (window.innerHeight - top) + 'px';
			const headerBg = getComputedStyle(headerEl).backgroundColor || 'red';
			menu.style.background = headerBg;
			// accessibility + block scroll + show close icon
			btn.setAttribute('aria-expanded', 'true');
			btn.setAttribute('aria-label', 'Close menu');
			if (burgerEl) burgerEl.style.display = 'none';
			if (closeEl) closeEl.style.display = 'block';
			document.body.style.overflow = 'hidden';
		}

		function closeMenu() {
			menu.style.display = 'none';
			menu.style.top = '';
			menu.style.height = '';
			btn.setAttribute('aria-expanded', 'false');
			btn.setAttribute('aria-label', 'Menu');
			if (burgerEl) burgerEl.style.display = 'flex';
			if (closeEl) closeEl.style.display = 'none';
			document.body.style.overflow = '';
		}

		btn.addEventListener('click', (e) => {
			e.stopPropagation();
			if (menu.style.display === 'flex') closeMenu(); else openMenu();
		});

		// Close when clicking outside
		document.addEventListener('click', (e) => {
			if (menu.style.display !== 'flex') return;
			if (btn.contains(e.target) || menu.contains(e.target)) return;
			closeMenu();
		});

		// (Closing via click on the close icon is handled because the button listener stays attached)

		// Adjust on resize if open
		window.addEventListener('resize', () => {
			if (menu.style.display !== 'flex') return;
			const rect = headerEl.getBoundingClientRect();
			const top = rect.bottom;
			menu.style.top = top + 'px';
			menu.style.height = (window.innerHeight - top) + 'px';
		});
	});
</script>

