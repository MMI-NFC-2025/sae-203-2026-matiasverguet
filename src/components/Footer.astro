---
import logo from '../assets/icons/logo.svg';
import insta from '../assets/icons/instagram.svg';
import xIcon from '../assets/icons/x.svg';
import fb from '../assets/icons/facebook.svg';
import youtube from '../assets/icons/youtube.svg';
---

<footer style="background:#151A25; color:white; padding:2rem 1rem;">
	<div style="max-width:1100px; margin:0 auto; display:flex; flex-direction:column;">
		<div style="display:flex; align-items:center;">
			<a href="/" style="display:inline-block;">
				<img src={logo.src} alt="Le Festival" style="height:64px; display:block;" />
			</a>
		</div>

		<div style="display:block; margin-top:2rem;">
			<div style="max-width:600px;">
				<div style="letter-spacing:1px; font-size:0.9rem; opacity:0.95;">MENU</div>
				<nav style="margin-top:1rem; display:flex; flex-direction:column; gap:0.75rem;">
					<a href="/evenement" style="color:inherit; text-decoration:none;">ÉVÉNEMENT</a>
					<a href="/contact" style="color:inherit; text-decoration:none;">CONTACT</a>
					<a href="/apropos" style="color:inherit; text-decoration:none;">À PROPOS</a>
				</nav>

				<div style="margin-top:2.5rem;">
					<div style="letter-spacing:1px; font-size:0.9rem; opacity:0.95;">NOUS SUIVRE</div>
						<div style="margin-top:1rem; display:flex; gap:1rem; align-items:center;">
							<a href="#" aria-label="Facebook" style="width:48px;height:48px;border-radius:50%;background:rgba(255,255,255,0.08);display:inline-flex;align-items:center;justify-content:center;text-decoration:none;color:white;padding:6px;">
								<img src={fb.src} alt="Facebook" style="width:24px;height:24px;display:block;" />
							</a>
							<a href="#" aria-label="Instagram" style="width:48px;height:48px;border-radius:50%;background:rgba(255,255,255,0.08);display:inline-flex;align-items:center;justify-content:center;text-decoration:none;color:white;padding:6px;">
								<img src={insta.src} alt="Instagram" style="width:24px;height:24px;display:block;" />
							</a>
							<a href="#" aria-label="X" style="width:48px;height:48px;border-radius:50%;background:rgba(255,255,255,0.08);display:inline-flex;align-items:center;justify-content:center;text-decoration:none;color:white;padding:6px;">
								<img src={xIcon.src} alt="X" style="width:24px;height:24px;display:block;" />
							</a>
							<a href="#" aria-label="YouTube" style="width:48px;height:48px;border-radius:50%;background:rgba(255,255,255,0.08);display:inline-flex;align-items:center;justify-content:center;text-decoration:none;color:white;padding:6px;">
								<img src={youtube.src} alt="YouTube" style="width:24px;height:24px;display:block;" />
							</a>
						</div>
				</div>
			</div>
		</div>

	</div>
</footer>

