---
// Composant Footer simple
---

<footer class="bg-[#151A25] text-white py-8 px-4">
  <div class="max-w-6xl mx-auto">
    
    <!-- Grille du footer -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      
      <!-- Colonne 1 : Logo et description -->
      <div>
        <h3 class="font-mono font-bold text-lg mb-3">Les Rives du Territoire</h3>
        <p class="text-white/70 text-sm">
          Festival de musique sur les berges de la Savoureuse a Belfort.
          20-23 decembre 2026.
        </p>
      </div>

      <!-- Colonne 2 : Liens rapides -->
      <div>
        <h4 class="font-bold mb-3">Liens rapides</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="text-white/70 hover:text-[#FDC700]">Accueil</a></li>
          <li><a href="/artistes" class="text-white/70 hover:text-[#FDC700]">Artistes</a></li>
          <li><a href="/festival" class="text-white/70 hover:text-[#FDC700]">Le Festival</a></li>
        </ul>
      </div>

      <!-- Colonne 3 : Contact -->
      <div>
        <h4 class="font-bold mb-3">Contact</h4>
        <ul class="space-y-2 text-sm text-white/70">
          <li>contact@lesrivesduterritoire.fr</li>
          <li>Belfort, France</li>
        </ul>
      </div>

    </div>

    <!-- Copyright -->
    <div class="border-t border-white/20 pt-4 text-center text-sm text-white/50">
      <p>2026 Les Rives du Territoire. Tous droits reserves.</p>
    </div>

  </div>
</footer>
