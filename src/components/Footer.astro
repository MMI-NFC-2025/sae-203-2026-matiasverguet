---
import facebook from '../assets/icons/facebook.svg';
import instagram from '../assets/icons/instagram.svg';
import xicon from '../assets/icons/x.svg';
import youtube from '../assets/icons/youtube.svg';
import logo from '../assets/icons/logo.svg';
---

<!-- CTA above footer -->
<section class="footer__cta">
    <div class="footer__container">
        <h2 class="footer__cta-title">Prêt à vibrer au rythme du territoire ?</h2>
        <p class="footer__cta-desc">Rejoignez-nous du 20 au 23 décembre 2026 aux Berges de la Savoureuse à Belfort pour une expérience inoubliable de musique, art et culture urbaine.</p>
        <a href="/billets" class="footer__cta-button">Acheter vos billets maintenant</a>
    </div>
</section>

<footer class="footer">
    <div class="footer__container">
        <div class="footer__logo">
            <img src={logo.src} alt="Les rives du Territoire" class="footer__logo-image">
        </div>

        <div class="footer__menu">
            <h3 class="footer__menu-title">MENU</h3>
            <nav class="footer__nav" aria-label="Navigation de pied de page">
                <ul class="footer__nav-list">
                    <li class="footer__nav-item"><a href="/festival" class="footer__nav-link">LE FESTIVAL</a></li>
                    <li class="footer__nav-item"><a href="/programme" class="footer__nav-link">PROGRAMME</a></li>
                    <li class="footer__nav-item"><a href="/artistes" class="footer__nav-link">ARTISTES</a></li>
                    <li class="footer__nav-item"><a href="/scenes" class="footer__nav-link">SCENES</a></li>
                    <li class="footer__nav-item"><a href="/infos" class="footer__nav-link">INFOS PRATIQUES</a></li>
                    <li class="footer__nav-item"><a href="/contact" class="footer__nav-link">CONTACT</a></li>
                </ul>
            </nav>
        </div>

        <div class="footer__social">
            <h3 class="footer__social-title">NOUS SUIVRE</h3>
            <div class="footer__social-links">
                <a href="https://www.facebook.com/?locale=fr_FR" class="footer__social-link" aria-label="Facebook">
                    <img src={facebook.src} alt="Facebook" class="footer__social-icon">
                </a>
                <a href="https://www.instagram.com/" class="footer__social-link" aria-label="Instagram">
                    <img src={instagram.src} alt="Instagram" class="footer__social-icon">
                </a>
                <a href="https://x.com/?lang=fr" class="footer__social-link" aria-label="X">
                    <img src={xicon.src} alt="X" class="footer__social-icon">
                </a>
                <a href="https://www.youtube.com/" class="footer__social-link" aria-label="YouTube">
                    <img src={youtube.src} alt="YouTube" class="footer__social-icon">
                </a>
            </div>
        </div>
    </div>
</footer>

<style>
/* Footer */
.footer {
    background-color: var(--color-black);
    padding: 3rem 1.5rem;
    color: var(--color-white);
}

.footer__container {
    max-width: 75rem;
    margin: 0 auto;
}

.footer__logo { margin-bottom: 3rem; }
.footer__logo-image { height: 5rem; width: auto; }

.footer__menu { margin-bottom: 3rem; }
.footer__menu-title {
    font-family: var(--typo-header);
    font-size: var(--fs-small);
    font-weight: var(--weight-blod);
    color: var(--color-gray);
    margin-bottom: 1rem;
}

.footer__nav-list { list-style: none; padding: 0; margin: 0; display:flex; flex-direction:column; gap:0rem; }
.footer__nav-item { margin:0 }
.footer__nav-link {
    color: var(--color-white); text-decoration:none; font-family:var(--typo-header);
    font-size:var(--fs-small); font-weight:var(--weight-regular); line-height:var(--line-height-2);
    transition: color 0.3s ease;
}

.footer__social { margin-bottom: 2rem; }
.footer__social-title { font-family:var(--typo-header); font-size:var(--fs-small); font-weight:var(--weight-blod); color:var(--color-gray); margin-bottom:1rem; }
.footer__social-links { display:flex; gap:1.5rem; align-items:center }
.footer__social-link { transition: opacity 0.3s ease; display:flex; align-items:center; justify-content:center }
.footer__social-link:hover { opacity:0.7 }
.footer__social-icon { width:2rem; height:2rem; display:block; filter:grayscale(100%) brightness(0.7); transition: filter 0.3s ease }

/* Responsive small screens: center content */
@media (max-width: 640px) {
  .footer__container { padding: 0 1rem }
  .footer__menu-title, .footer__social-title { text-align:center }
  .footer__menu, .footer__social { text-align:center }
}

/* CTA above footer */
.footer__cta {
    background: var(--color-black);
    color: var(--color-white);
    padding: 4.5rem 1.5rem 3rem;
    text-align: center;
}
.footer__cta .footer__container { max-width: 75rem; margin: 0 auto; }
.footer__cta-title {
    font-family: var(--typo-header, 'Courier New', monospace);
    font-size: 1.6rem; /* reduced from 2.25rem */
    margin: 0 0 1rem;
    font-weight: 700;
}
.footer__cta-desc {
    max-width: 60rem;
    margin: 0 auto 2.25rem;
    color: rgba(255,255,255,0.85);
}
.footer__cta-button {
    display: inline-block;
    background: #ffffff;
    color: var(--color-accent, #7c3aed);
    padding: 1rem 3.5rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    font-size: 1.125rem;
}

@media (max-width: 640px) {
    .footer__cta-title { font-size: 1.3rem }
    .footer__cta-button { width: 100%; display: inline-block; padding: 0.9rem 1rem }
}
</style>
