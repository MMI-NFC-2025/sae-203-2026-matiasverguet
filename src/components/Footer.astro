        </div>

      </div>

      <!-- Copyright -->
      <div class="border-t border-white/10 pt-6 text-center">
        <p class="text-white/40 text-sm">2026 Les Rives du Territoire. Tous droits reserves.</p>
      </div>

    </div>
  </div>
</footer>
