---
// Composant Footer - Design fidele au site original
---

<footer class="bg-[#1A1A2E] text-white border-t border-white/10">
  
  <!-- Section Partenaires -->
  <section class="py-12 px-6 border-b border-white/10">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-center text-sm uppercase tracking-widest text-white/50 mb-8">Nos Partenaires</h2>
      <div class="flex flex-wrap justify-center items-center gap-8 md:gap-12">
        <span class="text-white/40 text-sm">Belfort Tourisme</span>
        <span class="text-white/40 text-sm">Region Bourgogne-Franche-Comte</span>
        <span class="text-white/40 text-sm">Ville de Belfort</span>
        <span class="text-white/40 text-sm">Savoureuse Evenements</span>
        <span class="text-white/40 text-sm">Musique local</span>
        <span class="text-white/40 text-sm">Urban Culture</span>
      </div>
    </div>
  </section>

  <!-- Footer principal -->
  <div class="py-12 px-6">
    <div class="max-w-6xl mx-auto">
      
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
        
        <!-- Logo et description -->
        <div class="md:col-span-1">
          <h3 class="text-[#FDC700] font-bold text-lg mb-4 courier-prime-bold">Les rives du Territoire</h3>
          <p class="text-white/60 text-sm leading-relaxed">
            Festival de musique sur les berges de la Savoureuse a Belfort. 
            Vivez une experience unique au coeur du Territoire.
          </p>
        </div>

        <!-- Liens rapides -->
        <div>
          <h4 class="text-white font-bold text-sm uppercase tracking-wide mb-4">Navigation</h4>
          <ul class="space-y-2">
            <li><a href="/" class="text-white/60 hover:text-[#FDC700] text-sm transition-colors">Accueil</a></li>
            <li><a href="/artistes" class="text-white/60 hover:text-[#FDC700] text-sm transition-colors">Artistes</a></li>
            <li><a href="/festival" class="text-white/60 hover:text-[#FDC700] text-sm transition-colors">Programme</a></li>
            <li><a href="#billetterie" class="text-white/60 hover:text-[#FDC700] text-sm transition-colors">Billetterie</a></li>
          </ul>
        </div>

        <!-- Infos -->
        <div>
          <h4 class="text-white font-bold text-sm uppercase tracking-wide mb-4">Informations</h4>
          <ul class="space-y-2">
            <li><a href="#" class="text-white/60 hover:text-[#FDC700] text-sm transition-colors">Acces et transports</a></li>
            <li><a href="#" class="text-white/60 hover:text-[#FDC700] text-sm transition-colors">FAQ</a></li>
            <li><a href="#" class="text-white/60 hover:text-[#FDC700] text-sm transition-colors">Mentions legales</a></li>
          </ul>
        </div>

        <!-- Contact -->
        <div id="contact">
          <h4 class="text-white font-bold text-sm uppercase tracking-wide mb-4">Contact</h4>
          <ul class="space-y-2 text-sm text-white/60">
            <li>contact@lesrivesduterritoire.fr</li>
            <li>Belfort, France</li>
            <li class="pt-2">
              <div class="flex gap-4">
                <a href="#" class="text-white/60 hover:text-[#FDC700] transition-colors">
