---
// Props: title, description, img (metadata), href
const { title = '', description = '', img, href = '#' } = Astro.props;
import arrow from '../assets/icons/fleche_btn.svg';
---

<article class="card-index">
  {img ? (
    <div class="card-index__image">
      <img src={img.src ?? img} alt={title} />
    </div>
  ) : null}

  <div class="card-index__body">
    <h3 class="card-index__title">{title}</h3>
    <p class="card-index__description">{description}</p>
    <a class="card-index__link" href={href}>
      Découvrir
      <img src={arrow.src} alt="" aria-hidden="true" />
    </a>
  </div>
</article>

<style>
  .card-index {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto 2.5rem;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 18px 40px rgba(0,0,0,0.6);
    background: linear-gradient(00deg, var(--color-black), var(--color-gray));
  }

  .card-index__image img {
    display: block;
    width: 100%;
    height: 240px;
    object-fit: cover;
  }

  .card-index__body {
    padding: 2rem;
    color: var(--color-white);
    background: linear-gradient(180deg, var(--color-blackCard),var(--color-black));
  }

  .card-index__title {
    font-family: 'Courier New', Courier, monospace;
    font-size: 1.5rem;
    margin: 0 0 1rem;
    font-weight: 700;
    color: var(--color-white);
  }

  .card-index__description {
    margin: 0 0 1.5rem;
    color: rgba(255,255,255,0.85);
  }

  .card-index__link {
    color: var(--color-purpleCta, #8b5cf6);
    font-weight: 700;
    text-decoration: none;
    display: inline-flex;
    gap: .5rem;
    align-items: center;
  }

  .card-index__link img { width: 18px; height: 18px; }

  @media (max-width: 800px) {
    .card-index__image img { height: 180px }
    .card-index__body { padding: 1.25rem }
  }
</style>
