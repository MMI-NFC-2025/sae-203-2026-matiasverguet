---
// CardProg.astro
const { artiste } = Astro.props;

// Formatage de l'heure
const dateObj = new Date(artiste.date_representation);
const heure = dateObj.toLocaleTimeString('fr-FR', {
  hour: '2-digit',
  minute: '2-digit',
});

// Récupération du nom de la scène via l'expand
const nomScene = artiste.expand?.scene?.nom_scene || "Scène Principale";
---

<div class="flex flex-row items-center bg-[#111827] text-white p-6 rounded-xl gap-8 w-full border border-gray-800 shadow-xl">
  
  <div class="text-[#FFD700] text-4xl font-bold" style="min-width:120px;">
    {heure}
  </div>

  <div class="flex flex-col gap-1 text-left">
    <h2 class="text-2xl font-black uppercase tracking-tighter italic font-serif">
      {artiste.nom}
    </h2>
    
    <p class="text-gray-400 text-lg font-medium">
      {nomScene}
    </p>

    <div class="mt-3">
      <span class="bg-[#FFD700] text-black text-[10px] font-extrabold px-3 py-1 rounded-full uppercase">
        {artiste.genre_musical}
      </span>
    </div>
  </div>
</div>

<style>
  h2 {
    filter: drop-shadow(0px 2px 2px rgba(0,0,0,0.5));
  }
</style>