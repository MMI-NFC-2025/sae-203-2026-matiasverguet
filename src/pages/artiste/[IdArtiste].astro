---
import Layout from "../../layouts/Layout.astro";
import { artisteID, sceneID } from "../../../backend/backend.mjs";

const { IdArtiste } = Astro.params;
const artiste = await artisteID(IdArtiste);

// Resolve scene name from relation
let sceneName = "";
if (artiste.scene) {
	try {
		const scene = await sceneID(artiste.scene);
		sceneName = scene.nom_scene || "";
	} catch (_) {}
}

// Build hero image URL from galerie_photos
const fileName = Array.isArray(artiste.photo_principal) && artiste.photo_principal[0]
	? artiste.photo_principal[0]
	: artiste.photo_principal || "";
const imageUrl = fileName
	? `https://les-rives-du-territoire.verguet-bailly.fr/api/files/${artiste.collectionId}/${artiste.id}/${fileName}`
	: "";

// Format date
const dateStr = artiste.date_representation
	? new Date(artiste.date_representation).toLocaleDateString("fr-FR", {
			day: "2-digit",
			month: "long",
			year: "numeric",
	  })
	: "";

// Format time
const timeStr = artiste.date_representation
	? new Date(artiste.date_representation).toLocaleTimeString("fr-FR", {
			hour: "2-digit",
			minute: "2-digit",
	  })
	: "";

const genre = artiste.genre_musical || "";

// Build gallery image URLs
const galeriePhotos: string[] = Array.isArray(artiste.galerie_photos) ? artiste.galerie_photos : (artiste.galerie_photos ? [artiste.galerie_photos] : []);
const galerieUrls = galeriePhotos.map((f: string) => `https://les-rives-du-territoire.verguet-bailly.fr/api/files/${artiste.collectionId}/${artiste.id}/${f}`);
---

<Layout>
	<!-- Hero -->
	<section style="position:relative; width:100%; height:70vh; min-height:400px; overflow:hidden; display:flex; align-items:flex-end;">
		{imageUrl && (
			<img
				src={imageUrl}
				alt={artiste.nom}
				style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover;"
			/>
		)}
		<!-- Gradient overlay -->
		<div style="position:absolute; inset:0; background:linear-gradient(to top, #151A25 0%, rgba(21,26,37,0.4) 40%, transparent 100%);"></div>

		<!-- Content over the image -->
		<div style="position:relative; z-index:10; width:100%; padding:2rem 1.5rem; padding-bottom:2rem;" class="md:px-12 md:pb-12">
			<h1 class="text-white text-3xl md:text-5xl font-extrabold courier-prime-bold mb-3">
				{artiste.nom}
			</h1>
			<div style="display:flex; flex-wrap:wrap; align-items:center; gap:2rem;">
				<p class="text-white/80 text-sm md:text-base">
					{dateStr}{timeStr ? ` - ${timeStr}` : ""}
					{sceneName ? <span style="margin-left:2rem;">{sceneName}</span> : null}
				</p>
				{genre && (
					<span style="background-color:#FDC700; color:#000; font-size:0.75rem; font-weight:800; padding:0.25rem 1rem; border-radius:9999px; display:inline-block;">
						{genre}
					</span>
				)}
			</div>
		</div>
	</section>

	<!-- À propos de l'artiste -->
	<section class="bg-white py-16 px-6 md:px-12">
		<div class="max-w-3xl mx-auto">
			<h2 class="text-2xl md:text-3xl font-extrabold courier-prime-bold text-[#21252D] mb-6">
				À propos de l'artiste
			</h2>
			<div class="text-[#21252D]/80 text-base md:text-lg leading-relaxed space-y-4">
				{artiste.description
					? artiste.description.split("\n").filter(Boolean).map((p: string) => <p>{p}</p>)
					: <p>Aucune description disponible.</p>
				}
			</div>

			<!-- Bouton retour -->
			<div style="text-align:center; margin-top:2.5rem;">
				<a href="/artistes" style="display:inline-block; padding:0.75rem 2rem; border:2px solid #21252D; border-radius:9999px; color:#21252D; text-decoration:none; font-weight:700; font-size:1rem; transition:background 0.2s, color 0.2s;"
					onmouseover="this.style.background='#21252D';this.style.color='#fff';"
					onmouseout="this.style.background='transparent';this.style.color='#21252D';">
					Retour à la liste des artistes
				</a>
			</div>
		</div>
	</section>
	{galerieUrls.length > 0 && (
		<section style="background:#21252D; padding:4rem 1.5rem;">
			<h2 class="text-2xl md:text-3xl font-extrabold courier-prime-bold text-white text-center mb-8">
				Galerie
			</h2>
			<div style="position:relative; max-width:800px; margin:0 auto;">
				<!-- Carousel container -->
				<div id="carousel" style="overflow:hidden; border-radius:0.75rem;">
					<div id="carousel-track" style="display:flex; transition:transform 0.4s ease;">
						{galerieUrls.map((url: string, i: number) => (
							<img
								src={url}
								alt={`${artiste.nom} photo ${i + 1}`}
								style="min-width:100%; width:100%; height:450px; object-fit:cover;"
							/>
						))}
					</div>
				</div>

				<!-- Bouton précédent -->
				<button
					id="carousel-prev"
					aria-label="Photo précédente"
					style="position:absolute; left:-1.25rem; top:50%; transform:translateY(-50%); background:rgba(255,255,255,0.15); border:none; color:white; width:2.5rem; height:2.5rem; border-radius:50%; cursor:pointer; font-size:1.25rem; display:flex; align-items:center; justify-content:center;"
				>&#8249;</button>

				<!-- Bouton suivant -->
				<button
					id="carousel-next"
					aria-label="Photo suivante"
					style="position:absolute; right:-1.25rem; top:50%; transform:translateY(-50%); background:rgba(255,255,255,0.15); border:none; color:white; width:2.5rem; height:2.5rem; border-radius:50%; cursor:pointer; font-size:1.25rem; display:flex; align-items:center; justify-content:center;"
				>&#8250;</button>

				<!-- Indicateurs (dots) -->
				<div id="carousel-dots" style="display:flex; justify-content:center; gap:0.5rem; margin-top:1rem;">
					{galerieUrls.map((_: string, i: number) => (
						<button
							data-dot={i}
							aria-label={`Photo ${i + 1}`}
							style={`width:0.75rem; height:0.75rem; border-radius:50%; border:none; cursor:pointer; background:${i === 0 ? '#FDC700' : 'rgba(255,255,255,0.4)'};`}
						/>
					))}
				</div>
			</div>
		</section>
	)}
</Layout>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const track = document.getElementById('carousel-track');
		const prev = document.getElementById('carousel-prev');
		const next = document.getElementById('carousel-next');
		const dots = document.querySelectorAll('#carousel-dots button');
		if (!track || dots.length === 0) return;

		let current = 0;
		const total = dots.length;

		function goTo(index: number) {
			if (index < 0) index = total - 1;
			if (index >= total) index = 0;
			current = index;
			(track as HTMLElement).style.transform = `translateX(-${current * 100}%)`;
			dots.forEach((d, i) => {
				(d as HTMLElement).style.background = i === current ? '#FDC700' : 'rgba(255,255,255,0.4)';
			});
		}

		prev?.addEventListener('click', () => goTo(current - 1));
		next?.addEventListener('click', () => goTo(current + 1));
		dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)));
	});
</script>
