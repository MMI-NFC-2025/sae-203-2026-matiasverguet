---
// Page dynamique pour un artiste
import Layout from '../../layouts/Layout.astro';
import { artisteID, sceneID } from '../../../backend/backend.mjs';

// On recupere l'id depuis l'URL
const { id } = Astro.params;

// Variables pour stocker les donnees
let artiste = null;
let scene = null;
let erreur = null;

try {
  // On recupere l'artiste par son ID
  artiste = await artisteID(id);
  
  // Si l'artiste a une scene, on la recupere
  if (artiste.scene) {
    scene = await sceneID(artiste.scene);
  }
} catch (e) {
  erreur = "Artiste non trouve.";
  console.error(e);
}

// URL de l'image depuis PocketBase
const imageUrl = artiste?.photo 
  ? `http://127.0.0.1:8090/api/files/artistes/${artiste.id}/${artiste.photo}`
  : '/placeholder.jpg';

// Formater la date
function formatDate(dateString) {
  if (!dateString) return 'Date a confirmer';
  const date = new Date(dateString);
  return date.toLocaleDateString('fr-FR', {
    weekday: 'long',
    day: 'numeric',
    month: 'long',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
  });
}
---

<Layout>
  {erreur ? (
    <!-- Message d'erreur -->
    <section class="py-28 px-6 text-center">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-3xl font-bold text-white mb-4">{erreur}</h1>
        <a href="/artistes" class="text-[#FDC700] hover:underline">
          Retour a la liste des artistes
        </a>
      </div>
    </section>
  ) : (
    <!-- Contenu de l'artiste -->
    <section class="py-28 px-6">
      <div class="max-w-4xl mx-auto">

        <!-- Bouton retour -->
        <a href="/artistes" class="inline-flex items-center text-white/70 hover:text-white mb-8">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
          Retour aux artistes
        </a>

        <!-- Carte principale -->
        <div class="bg-[#151A25] rounded-2xl overflow-hidden">
          
          <!-- Image grande -->
          <div class="h-64 md:h-96 overflow-hidden">
            <img 
              src={imageUrl} 
              alt={artiste.nom} 
              class="w-full h-full object-cover"
            />
          </div>

          <!-- Infos -->
          <div class="p-6 md:p-8">
            
            <!-- Nom -->
            <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">
              {artiste.nom}
            </h1>

            <!-- Date et scene -->
            <div class="flex flex-wrap gap-4 mb-6">
              <div class="bg-[#FDC700] text-black px-4 py-2 rounded-lg font-medium">
                {formatDate(artiste.date_representation)}
              </div>
              
              {scene && (
                <div class="bg-white/10 text-white px-4 py-2 rounded-lg">
                  {scene.nom}
                </div>
              )}
            </div>

            <!-- Description -->
            {artiste.description && (
              <div class="text-white/80 leading-relaxed">
                <h2 class="text-xl font-bold text-white mb-3">A propos</h2>
                <p>{artiste.description}</p>
              </div>
            )}

          </div>
        </div>

      </div>
    </section>
  )}
</Layout>
