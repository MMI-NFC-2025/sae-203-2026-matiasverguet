---
import Layout from '../../layouts/Layout.astro';
import { artistesName, scenesName } from '../../../backend/backend.mjs';

const artistes = await artistesName();
const scenes = await scenesName();

const pbUrl = 'http://127.0.0.1:8090';

function getImageUrl(record, field) {
  if (!record[field]) return null;
  return `${pbUrl}/api/files/${record.collectionId}/${record.id}/${record[field]}`;
}
---

<Layout>
  <!-- Page Header -->
  <section class="py-28 px-6 text-center">
    <div class="max-w-4xl mx-auto">
      <h1 class="font-mono text-4xl md:text-5xl font-bold text-white mb-2">Les Artistes</h1>
      <p class="text-white/90 text-lg md:text-xl">Découvrez les talents qui animeront le festival</p>
    </div>
  </section>

  <!-- Search and Filter -->
  <section class="px-6 pb-8">
    <div class="max-w-6xl mx-auto">
      <!-- Search Bar -->
      <div class="mb-6">
        <div class="relative max-w-md mx-auto">
          <input 
            type="text" 
            id="search-input"
            placeholder="Rechercher un artiste..." 
            class="w-full bg-[#151A25] border border-[#2A2A3E] rounded-full px-5 py-3 text-white placeholder-white/40 focus:outline-none focus:border-[#432766] transition-colors"
          />
          <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-5 h-5 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </div>
      </div>
      
      <!-- Genre Filter -->
      <div class="flex flex-wrap gap-3 justify-center">
        <button class="genre-btn active px-4 py-2 rounded-full bg-[#432766] text-white font-medium transition-all hover:bg-[#5a3a8a]" data-genre="all">
          Tous les genres
        </button>
        {[...new Set(artistes.map(a => a.genre_musical).filter(Boolean))].map((genre) => (
          <button class="genre-btn px-4 py-2 rounded-full bg-[#1A1A2E] text-white/80 font-medium transition-all hover:bg-[#2A2A3E] border border-[#2A2A3E]" data-genre={genre}>
            {genre}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Artists Grid -->
  <section class="px-6 pb-16">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6" id="artistes-grid">
        {artistes.map((artiste) => {
          const imageUrl = getImageUrl(artiste, 'photo_principal');
          const scene = scenes.find(s => s.id === artiste.scene);
          const date = artiste.date_representation 
            ? new Date(artiste.date_representation).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long' })
            : null;
          
          return (
            <a href={`/artistes/${artiste.id}`} class="artiste-card group" data-name={artiste.nom?.toLowerCase() || ''} data-genre={artiste.genre_musical || ''}>
              <article class="bg-[#151A25] rounded-xl overflow-hidden border border-[#2A2A3E] transition-all hover:border-[#432766] hover:shadow-lg hover:shadow-purple-900/20 h-full">
                <div class="aspect-square overflow-hidden relative">
                  {imageUrl ? (
                    <img src={imageUrl} alt={artiste.nom} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                  ) : (
                    <div class="w-full h-full bg-[#1A1A2E] flex items-center justify-center">
                      <svg class="w-16 h-16 text-white/20" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                      </svg>
                    </div>
                  )}
                  {date && (
                    <div class="absolute bottom-3 left-3 bg-black/70 text-[#FDC700] px-3 py-1 rounded-full text-xs font-bold">
                      {date}
                    </div>
                  )}
                </div>
                
                <div class="p-4">
                  <h3 class="text-lg font-bold text-white mb-2 group-hover:text-[#FDC700] transition-colors">
                    {artiste.nom}
                  </h3>
                  
                  <div class="flex flex-wrap gap-2">
                    {artiste.genre_musical && (
                      <span class="text-xs bg-[#2A1F5C] text-white/80 px-2 py-1 rounded">
                        {artiste.genre_musical}
                      </span>
                    )}
                    {scene && (
                      <span class="text-xs bg-[#1A1A2E] text-[#FDC700] px-2 py-1 rounded border border-[#432766]">
                        {scene.nom_scene}
                      </span>
                    )}
                  </div>
                </div>
              </article>
            </a>
          );
        })}
      </div>
      
      {artistes.length === 0 && (
        <div class="text-center py-16">
          <p class="text-white/60 text-lg">Aucun artiste n'est encore annonce.</p>
          <p class="text-white/40 mt-2">Revenez bientot pour decouvrir notre programmation !</p>
        </div>
      )}
      
      <!-- No results message -->
      <div id="no-results" class="text-center py-16 hidden">
        <p class="text-white/60 text-lg">Aucun artiste trouve.</p>
        <p class="text-white/40 mt-2">Essayez une autre recherche.</p>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('search-input');
    const genreBtns = document.querySelectorAll('.genre-btn');
    const cards = document.querySelectorAll('.artiste-card');
    const noResults = document.getElementById('no-results');
    
    let currentGenre = 'all';
    let currentSearch = '';
    
    function filterCards() {
      let visibleCount = 0;
      
      cards.forEach(card => {
        const name = card.dataset.name || '';
        const genre = card.dataset.genre || '';
        
        const matchesSearch = currentSearch === '' || name.includes(currentSearch.toLowerCase());
        const matchesGenre = currentGenre === 'all' || genre === currentGenre;
        
        if (matchesSearch && matchesGenre) {
          card.style.display = 'block';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });
      
      noResults.classList.toggle('hidden', visibleCount > 0);
    }
    
    searchInput?.addEventListener('input', (e) => {
      currentSearch = e.target.value;
      filterCards();
    });
    
    genreBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        currentGenre = btn.dataset.genre;
        
        genreBtns.forEach(b => {
          b.classList.remove('active', 'bg-[#432766]');
          b.classList.add('bg-[#1A1A2E]');
        });
        btn.classList.add('active', 'bg-[#432766]');
        btn.classList.remove('bg-[#1A1A2E]');
        
        filterCards();
      });
    });
  });
</script>

<style>
  .genre-btn.active {
    background-color: #432766 !important;
  }
</style>
