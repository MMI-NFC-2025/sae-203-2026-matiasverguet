---
// Page liste des artistes - Design fidele au site original
import Layout from '../../layouts/Layout.astro';
import ArtisteCard from '../../components/ArtisteCard.astro';
import { artistesSorted } from '../../../backend/backend.mjs';

// On recupere tous les artistes
let artistes = [];
let erreur = null;

try {
  artistes = await artistesSorted();
} catch (e) {
  erreur = "Impossible de charger les artistes. Verifiez que PocketBase est lance.";
  console.error(e);
}
---

<Layout>
  
  <!-- Hero de la page -->
  <section class="relative py-32 px-6 text-center bg-gradient-to-b from-[#2A1F5C] to-[#1A1A2E] overflow-hidden">
    
    <!-- Effet de fond -->
    <div class="absolute inset-0 opacity-20">
      <div class="absolute top-0 left-1/4 w-64 h-64 bg-[#8b5cf6] rounded-full filter blur-[100px]"></div>
      <div class="absolute bottom-0 right-1/4 w-64 h-64 bg-[#FDC700] rounded-full filter blur-[100px]"></div>
    </div>
    
    <div class="relative z-10 max-w-4xl mx-auto">
      <p class="text-[#FDC700] text-sm uppercase tracking-widest mb-4">Programmation 2026</p>
      <h1 class="courier-prime-bold text-4xl md:text-5xl lg:text-6xl text-white mb-4">
        Les Artistes
      </h1>
      <p class="text-white/70 text-lg max-w-xl mx-auto">
        Decouvrez tous les artistes qui enflammeront la scene du festival
      </p>
    </div>
  </section>

  <!-- Message d'erreur -->
  {erreur && (
    <section class="py-8 px-6">
      <div class="max-w-4xl mx-auto">
        <div class="bg-red-500/20 border border-red-500/50 text-red-200 p-4 rounded-xl text-center">
          {erreur}
        </div>
      </div>
    </section>
  )}

  <!-- Grille des artistes -->
  <section class="py-16 px-6 bg-[#1A1A2E]">
    <div class="max-w-6xl mx-auto">

      {artistes.length === 0 && !erreur && (
        <p class="text-white/50 text-center py-12">Aucun artiste trouve pour le moment.</p>
      )}

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {artistes.map((artiste) => (
          <ArtisteCard artiste={artiste} />
        ))}
      </div>

    </div>
  </section>

</Layout>
