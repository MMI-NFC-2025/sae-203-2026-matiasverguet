---
import Layout from "../layouts/Layout.astro";
import CardArtistes from "../components/cardArtistes.astro";
import { artistesName, artistesSorted } from '../../backend/backend.mjs';

const artistesByName = await artistesName();
const artistesByDate = await artistesSorted();
---

<Layout>
	<!-- Banner under header -->
	<section class="w-full bg-[#151A25]">
		<div class="max-w-6xl mx-auto px-4 py-12 text-center">
			<h2 class="text-white text-4xl md:text-5xl font-bold courier-prime-bold">Les Artistes</h2>
			<p class="text-white/80 mt-4 text-lg md:text-xl">Découvrez tous les talents du festival</p>
		</div>
	</section>

	<!-- Boutons de tri -->
	<section class="w-full bg-[#1c2333] py-6">
		<div class="flex justify-center gap-4">
			<button data-sort="name" class="sort-btn active px-6 py-2 rounded-full text-sm font-bold border border-white/20 transition-colors">
				Par nom
			</button>
			<button data-sort="date" class="sort-btn px-6 py-2 rounded-full text-sm font-bold border border-white/20 transition-colors">
				Par date
			</button>
		</div>
	</section>

	<section class="max-w-6xl mx-auto px-4 py-12">
		<!-- Grille triée par nom -->
		<div id="grid-name" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
			{artistesByName.length === 0 ? (
				<p class="col-span-full text-center text-gray-500">Aucun artiste trouvé.</p>
			) : (
				artistesByName.map((a) => (
					<CardArtistes artiste={a} />
				))
			)}
		</div>

		<!-- Grille triée par date -->
		<div id="grid-date" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8 hidden">
			{artistesByDate.length === 0 ? (
				<p class="col-span-full text-center text-gray-500">Aucun artiste trouvé.</p>
			) : (
				artistesByDate.map((a) => (
					<CardArtistes artiste={a} />
				))
			)}
		</div>
	</section>
</Layout>

<style>
	.sort-btn {
		color: white;
		background: transparent;
		cursor: pointer;
	}
	.sort-btn.active {
		background: #FFD700;
		color: black;
		border-color: #FFD700;
	}
</style>

<script>
	document.querySelectorAll('.sort-btn').forEach(btn => {
		btn.addEventListener('click', () => {
			document.querySelectorAll('.sort-btn').forEach(b => b.classList.remove('active'));
			btn.classList.add('active');

			const sort = btn.getAttribute('data-sort');
			document.getElementById('grid-name')!.classList.toggle('hidden', sort !== 'name');
			document.getElementById('grid-date')!.classList.toggle('hidden', sort !== 'date');
		});
	});
</script>