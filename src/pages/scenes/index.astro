---
import Layout from '../../layouts/Layout.astro';
import { scenesName, allartistebysceneId } from '../../../backend/backend.mjs';

const scenes = await scenesName();

const pbUrl = 'http://127.0.0.1:8090';

function getImageUrl(record, field) {
  if (!record[field]) return null;
  return `${pbUrl}/api/files/${record.collectionId}/${record.id}/${record[field]}`;
}

// Get artist count for each scene
const scenesWithArtists = await Promise.all(scenes.map(async (scene) => {
  try {
    const artistes = await allartistebysceneId(scene.id);
    return { ...scene, artisteCount: artistes.length };
  } catch {
    return { ...scene, artisteCount: 0 };
  }
}));
---

<Layout>
  <!-- Page Header -->
  <section class="py-28 px-6 text-center">
    <div class="max-w-4xl mx-auto">
      <h1 class="font-mono text-4xl md:text-5xl font-bold text-white mb-2">Les Scenes</h1>
      <p class="text-white/90 text-lg md:text-xl">Decouvrez les differentes scenes du festival</p>
    </div>
  </section>

  <!-- Scenes Grid -->
  <section class="px-6 pb-16">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {scenesWithArtists.map((scene) => {
          const imageUrl = getImageUrl(scene, 'photo_scene');
          
          return (
            <a href={`/scenes/${scene.id}`} class="group">
              <article class="bg-[#151A25] rounded-2xl overflow-hidden border border-[#2A2A3E] transition-all hover:border-[#432766] hover:shadow-xl hover:shadow-purple-900/30 h-full">
                <div class="h-64 overflow-hidden relative">
                  {imageUrl ? (
                    <img src={imageUrl} alt={scene.nom_scene} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                  ) : (
                    <div class="w-full h-full bg-gradient-to-br from-[#2A1F5C] to-[#432766] flex items-center justify-center">
                      <svg class="w-20 h-20 text-white/30" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
                      </svg>
                    </div>
                  )}
                  
                  <!-- Overlay with scene name -->
                  <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex items-end">
                    <div class="p-6 w-full">
                      <h2 class="text-2xl md:text-3xl font-bold text-white font-mono group-hover:text-[#FDC700] transition-colors">
                        {scene.nom_scene}
                      </h2>
                    </div>
                  </div>
                </div>
                
                <div class="p-6">
                  <div class="flex flex-wrap gap-4 mb-4">
                    {scene.capacite && (
                      <div class="flex items-center gap-2 text-white/70">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                        </svg>
                        <span>{scene.capacite} places</span>
                      </div>
                    )}
                    {scene.localisation && (
                      <div class="flex items-center gap-2 text-white/70">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        </svg>
                        <span>{scene.localisation}</span>
                      </div>
                    )}
                  </div>
                  
                  {scene.description && (
                    <p class="text-white/70 mb-4 line-clamp-2">{scene.description}</p>
                  )}
                  
                  <div class="flex items-center justify-between">
                    <span class="text-[#FDC700] font-medium">
                      {scene.artisteCount} artiste{scene.artisteCount > 1 ? 's' : ''} programme{scene.artisteCount > 1 ? 's' : ''}
                    </span>
                    <span class="text-[#432766] group-hover:text-[#FDC700] transition-colors flex items-center gap-1 font-medium">
                      Voir les details
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                      </svg>
                    </span>
                  </div>
                </div>
              </article>
            </a>
          );
        })}
      </div>
      
      {scenes.length === 0 && (
        <div class="text-center py-16">
          <p class="text-white/60 text-lg">Aucune scene n'est encore configuree.</p>
          <p class="text-white/40 mt-2">Revenez bientot pour decouvrir nos scenes !</p>
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
