---
import Layout from "../layouts/Layout.astro";
import CardProg from '../components/CardProg.astro';
import PocketBase from 'pocketbase';

const pb = new PocketBase('http://127.0.0.1:8090');

// Récupération des données avec l'expand pour la scène
const records = await pb.collection('artistes').getFullList({ 
  sort: 'date_representation',
  expand: 'scene' 
});

// Grouper les artistes par date (YYYY-MM-DD)
function groupByDay(list) {
  const map = new Map();
  for (const item of list) {
    const d = item.date_de_representation || item.date_representation || item.created;
    const day = d ? new Date(d).toISOString().slice(0,10) : 'unknown';
    if (!map.has(day)) map.set(day, []);
    map.get(day).push(item);
  }
  return Array.from(map.entries()).sort((a,b) => a[0].localeCompare(b[0]));
}

const groups = groupByDay(records);
---
<Layout title="Programmation du Festival">
    <section class="w-full bg-[#151A25]">
		<div class="max-w-6xl mx-auto px-4 py-12 text-center">
			<h2 class="text-white text-4xl md:text-5xl font-bold courier-prime-bold">Programme</h2>
			<p class="text-white/80 mt-4 text-lg md:text-xl">Découvrez la programmation complète du festival</p>
		</div>
	</section>
  <main class="p-10 flex flex-col gap-6 bg-white min-h-screen">

    

    <div class="flex flex-col gap-8">
      {groups.map(([day, items]) => (
        <section key={day}>
          <header class="max-w-6xl mx-auto px-4 mb-6">
            <h3 class="text-2xl font-bold courier-prime-bold">{new Date(day).toLocaleDateString('fr-FR', { weekday: 'long', day: '2-digit', month: 'long', year: 'numeric' })}</h3>
            <p class="text-gray-500">Programme complet</p>
            <div class="mt-4 border-t-2 border-yellow-400"></div>
          </header>

          <div class="max-w-6xl mx-auto px-4">
            <div class="flex flex-col gap-6">
              {items.map((artiste) => (
                <CardProg artiste={artiste} />
              ))}
            </div>
          </div>
        </section>
      ))}
    </div>
  </main>
</Layout>