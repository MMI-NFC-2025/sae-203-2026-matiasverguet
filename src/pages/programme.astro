---
import Layout from "../layouts/Layout.astro";
import CardProg from '../components/CardProg.astro';
import { artistesSorted } from '../../backend/backend.mjs';

const records = await artistesSorted();

// Grouper les artistes par date (YYYY-MM-DD)
function groupByDay(list) {
  const map = new Map();
  for (const item of list) {
    const d = item.date_de_representation || item.date_representation || item.created;
    const day = d ? new Date(d).toISOString().slice(0,10) : 'unknown';
    if (!map.has(day)) map.set(day, []);
    map.get(day).push(item);
  }
  return Array.from(map.entries()).sort((a,b) => a[0].localeCompare(b[0]));
}

const groups = groupByDay(records);
const dayLabels = groups.map(([day]) => ({
  key: day,
  label: new Date(day).toLocaleDateString('fr-FR', { day: '2-digit', month: 'long' })
}));
---
<Layout title="Programmation du Festival">
    <section class="w-full bg-[#151A25]">
		<div class="max-w-6xl mx-auto px-4 py-12 text-center">
			<h2 class="text-white text-4xl md:text-5xl font-bold courier-prime-bold">Programme</h2>
			<p class="text-white/80 mt-4 text-lg md:text-xl">Découvrez la programmation complète du festival</p>
		</div>
	</section>

  <!-- Filtres par jour -->
  <section class="w-full bg-[#1c2333] py-6">
    <div class="flex flex-wrap justify-center gap-3">
      <button data-filter="all" class="filter-btn active px-6 py-2 rounded-full text-sm font-bold border border-white/20 transition-colors">
        Tous
      </button>
      {dayLabels.map(({ key, label }) => (
        <button data-filter={key} class="filter-btn px-6 py-2 rounded-full text-sm font-bold border border-white/20 transition-colors">
          {label}
        </button>
      ))}
    </div>
  </section>

  <main class="p-10 flex flex-col gap-6 bg-white min-h-screen">

    <div class="flex flex-col gap-8">
      {groups.map(([day, items]) => (
        <section data-day={day}>
          <header class="max-w-6xl mx-auto px-4 mb-6">
            <h3 class="text-2xl font-bold courier-prime-bold">{new Date(day).toLocaleDateString('fr-FR', { weekday: 'long', day: '2-digit', month: 'long', year: 'numeric' })}</h3>
            <p class="text-gray-500">Programme complet</p>
            <div class="mt-4 border-t-2 border-yellow-400"></div>
          </header>

          <div class="max-w-6xl mx-auto px-4">
            <div class="flex flex-col gap-6">
              {items.map((artiste) => (
                <CardProg artiste={artiste} />
              ))}
            </div>
          </div>
        </section>
      ))}
    </div>
  </main>
</Layout>

<style>
  .filter-btn {
    color: white;
    background: transparent;
    cursor: pointer;
  }
  .filter-btn.active {
    background: #FFD700;
    color: black;
    border-color: #FFD700;
  }
</style>

<script>
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const filter = btn.getAttribute('data-filter');
      document.querySelectorAll('[data-day]').forEach(section => {
        if (filter === 'all' || section.getAttribute('data-day') === filter) {
          (section as HTMLElement).style.display = '';
        } else {
          (section as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>