---
import Layout from "../layouts/Layout.astro";
import CardScene from "../components/CardScene.astro";
import { scenesName } from "../../backend/backend.mjs";

let scenes = [];
let scenesFetchError = null;
try {
  scenes = await scenesName();
  if (!Array.isArray(scenes)) scenes = [];
} catch (e) {
  scenesFetchError = String(e?.message || e);
  scenes = [];
}
---

<Layout title="Les Scènes du Festival">
    <section class="w-full bg-[#151A25]">
		<div class="max-w-6xl mx-auto px-4 py-12 text-center">
			<h2 class="text-white text-4xl md:text-5xl font-bold courier-prime-bold">Les Scènes</h2>
			<p class="text-white/80 mt-4 text-lg md:text-xl">Découvrez les différents espaces du festival</p>
		</div>
	</section>
  <main class="bg-[#ffffff] pt-8 pb-0 px-8">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10 pb-6">
      {scenesFetchError ? (
        <div class="col-span-1 md:col-span-2 bg-red-100 text-red-800 p-4 rounded">Erreur récupération scènes: {scenesFetchError}</div>
      ) : scenes.length === 0 ? (
        <div class="col-span-1 md:col-span-2 p-6 bg-yellow-50 text-yellow-800 rounded">
          <p class="font-bold">Aucune scène trouvée.</p>
          <p class="text-sm mt-2">Debug: scenes.length = {scenes.length}</p>
          <pre class="mt-3 text-xs text-gray-700 overflow-auto max-h-48 bg-white p-2 rounded">{JSON.stringify(scenes, null, 2)}</pre>
        </div>
      ) : (
        scenes.map((scene) => (
          <CardScene scene={scene} />
        ))
      )}
    </div>

  </main>
</Layout>